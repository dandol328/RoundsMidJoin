<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      BepInEx maintains its own NuGet feed for packages such as BepInEx.Core.
      Add this if you want to pull BepInEx directly from NuGet instead of from
      a local game installation.
    -->
    <add key="BepInEx" value="https://nuget.bepinex.dev/v3/index.json" />
  </packageSources>
</configuration>
